# Linkbreakers API Configuration
# Copy this file to .env and fill in your values

# Required: Your Linkbreakers API key
# Get your API key from: https://app.linkbreakers.com/settings/tokens
LINKBREAKERS_API_KEY=your-api-key-here

# Optional: API base URL (defaults to production)
# LINKBREAKERS_API_URL=https://api.linkbreakers.com

# Optional: Custom domain UUID (for branded links)
# LINKBREAKERS_CUSTOM_DOMAIN_ID=your-custom-domain-uuid
